{
  "name": "noxo-audit-engine",
  "version": "1.0.0",
  "description": "Auditoría de accesibilidad web con axe-core, Lighthouse, Pa11y y Playwright",
  "type": "module",
  "scripts": {
    "audit": "node --import tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
