    "chrome-launcher": "^1.1.2",
    "lighthouse": "^12.2.1",
    "pa11y": "^8.0.0",
    "playwright": "^1.48.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
